<Window x:Class="SahneSenin.DisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Sahne Senin - TV Ekranı" Height="600" Width="800"
        Background="{StaticResource WindowBgGradient}"
        WindowStyle="None" WindowState="Normal"
        KeyDown="Window_KeyDown" MouseDoubleClick="Window_MouseDoubleClick" Focusable="True">

    <Window.Resources>
        <!-- State-based Visibility Styles for TV Screen -->
        <Style x:Key="SetupVisibleStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentState}" Value="Setup">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="SelectionVisibleStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentState}" Value="TeacherSelection">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="GameVisibleStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentState}" Value="Game">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="ScoreVisibleStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentState}" Value="Score">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GuessPhaseVisibleStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentState}" Value="GuessPhase">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Background decorative neon glows -->
        <Ellipse Width="400" Height="400" Fill="#0800F2FE" Margin="-200,-200,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Ellipse Width="500" Height="500" Fill="#08FF007F" Margin="0,0,-250,-250" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>

        <!-- MAIN CONTENT SWITCHER -->
        <Grid Margin="40">
            
            <!-- STATE: Setup -->
            <Grid Style="{StaticResource SetupVisibleStyle}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="SAHNE SENİN" Style="{StaticResource TitleText}" FontSize="72" HorizontalAlignment="Center" Effect="{StaticResource PinkGlow}" Margin="0,0,0,20"/>
                    <TextBlock Text="MÜZİK YARIŞMASINA HOŞ GELDİNİZ" Foreground="{StaticResource NeonCyanBrush}" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" Effect="{StaticResource CyanGlow}" Margin="0,0,0,20"/>
                    <TextBlock Text="Sunucu listeyi yüklediğinde eğlence başlayacak!" Foreground="{StaticResource TextMutedBrush}" FontSize="18" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>

            <!-- STATE: TeacherSelection (Roulette Wheel / Roll list) -->
            <!-- STATE: TeacherSelection (Roulette Wheel / Roll list) -->
            <Grid Style="{StaticResource SelectionVisibleStyle}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,20,0,10">
                    <TextBlock Text="SIRADAKİ YARIŞMACI" Style="{StaticResource TitleText}" FontSize="36" HorizontalAlignment="Center" Effect="{StaticResource CyanGlow}"/>
                    <TextBlock Text="Kimin sahnesi olacağını belirleme zamanı!" Style="{StaticResource SubTitleText}" FontSize="18" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Side-by-Side Container -->
                <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20,0,20,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/> <!-- Spacing column -->
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="40"/> <!-- Spacing column -->
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Circular Spin the Wheel Grid -->
                    <Grid Grid.Column="0" Width="500" Height="500" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Outer Glowing Rim -->
                        <Ellipse Width="490" Height="490" Stroke="{StaticResource NeonPinkBrush}" StrokeThickness="5" Effect="{StaticResource PinkGlow}" Fill="#15000000"/>
                        <Ellipse Width="476" Height="476" Stroke="{StaticResource NeonCyanBrush}" StrokeThickness="2" Effect="{StaticResource CyanGlow}"/>

                        <!-- Rotating Wheel Container -->
                        <Grid x:Name="WheelContainer" Width="460" Height="460" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <RotateTransform x:Name="WheelRotation" Angle="0"/>
                            </Grid.RenderTransform>
                            <!-- The dynamic canvas where slices and texts are generated -->
                            <Canvas x:Name="WheelCanvas" Width="460" Height="460"/>
                        </Grid>

                        <!-- Central Static Cap (Pointer cap) -->
                        <Ellipse Width="70" Height="70" Fill="{StaticResource CardBgBrush}" Stroke="{StaticResource NeonCyanBrush}" StrokeThickness="3" Effect="{StaticResource CyanGlow}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Text="🎯" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-3,0,0" Effect="{StaticResource CyanGlow}"/>

                        <!-- Pointer Arrow at the top (pointing down) -->
                        <Polygon Points="0,0 30,0 15,30" Fill="{StaticResource NeonYellowBrush}" Effect="{StaticResource GreenGlow}" 
                                 HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-12,0,0"/>
                    </Grid>

                    <!-- Right: Winner Card (shown after spin completes or while waiting) -->
                    <Border Grid.Column="2" BorderBrush="{StaticResource NeonPinkBrush}" Effect="{StaticResource PinkGlow}"
                            CornerRadius="16" Padding="30,25" Width="480" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSpinCompleted}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <!-- Avatar / Photo -->
                            <Grid Height="80" Width="80" Margin="0,0,0,10" HorizontalAlignment="Center">
                                <Border CornerRadius="40" BorderThickness="2" BorderBrush="{StaticResource NeonCyanBrush}" ClipToBounds="True" Height="80" Width="80" Effect="{StaticResource CyanGlow}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentTeacher.HasPhoto}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Image Source="{Binding CurrentTeacher.PhotoPath}" Stretch="UniformToFill"/>
                                </Border>
                                <Border CornerRadius="40" BorderThickness="2" BorderBrush="{StaticResource NeonPinkBrush}" Height="80" Width="80" Effect="{StaticResource PinkGlow}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource PinkGradient}"/>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentTeacher.HasPhoto}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding CurrentTeacher.Initials}" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                                </Border>
                            </Grid>

                            <TextBlock Text="SEÇİLEN YARIŞMACI" FontSize="14" FontWeight="Bold"
                                        Foreground="{StaticResource NeonCyanBrush}"
                                        HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding CurrentTeacher.Name}" FontSize="36" FontWeight="Bold"
                                        Foreground="White" TextAlignment="Center" HorizontalAlignment="Center"
                                        Effect="{StaticResource PinkGlow}" TextWrapping="Wrap" Margin="0,0,0,25"/>

                            <TextBlock Text="Sunucu 'Yarışmayı Başlat' butonuna basana kadar bekleniyor..."
                                        FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                        HorizontalAlignment="Center" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Far Right: All Artists Pool (shown after spin completes or while waiting) -->
                    <Border Grid.Column="4" BorderBrush="{StaticResource NeonYellowBrush}" Effect="{StaticResource GreenGlow}"
                            CornerRadius="16" Padding="20" Width="280" Height="400" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSpinCompleted}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Title -->
                            <TextBlock Grid.Row="0" Text="SANATÇI HAVUZU" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource NeonYellowBrush}" Effect="{StaticResource GreenGlow}"
                                       HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            
                            <!-- Scrollable list of system artists -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding AllSystemArtists}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,6" Padding="10,6" CornerRadius="8" Background="#12FFFFFF" BorderThickness="1" BorderBrush="#20FFFFFF">
                                                <TextBlock Text="{Binding}" Foreground="White" FontSize="13" FontWeight="SemiBold" TextAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>

            <!-- STATE: Game (Contestant and 10s Countdown) -->
            <Grid Style="{StaticResource GameVisibleStyle}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Contestant Header -->
                <StackPanel Grid.Row="0" Margin="0,20,0,0">
                    <TextBlock Text="SAHNE SENDE!" Style="{StaticResource TitleText}" FontSize="36" Foreground="{StaticResource NeonCyanBrush}" HorizontalAlignment="Center" Effect="{StaticResource CyanGlow}"/>
                    <TextBlock Text="{Binding CurrentAttempt, StringFormat='Hak: {0} / 3'}" Foreground="{StaticResource NeonYellowBrush}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Effect="{StaticResource CyanGlow}" Margin="0,5,0,0"/>
                    <TextBlock Text="Şarkıyı tahmin et ve puanı kap!" Style="{StaticResource SubTitleText}" FontSize="18" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    <!-- Mode/Risk Badges -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                        <Border Background="#20FFE600" BorderBrush="{StaticResource NeonYellowBrush}" BorderThickness="1" CornerRadius="4" Padding="8,2" Margin="5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UseAllArtistsPool}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="TÜM SANATÇILAR (2x PUAN)" FontSize="12" FontWeight="Bold" Foreground="{StaticResource NeonYellowBrush}"/>
                        </Border>
                        <Border Background="#20FF007F" BorderBrush="{StaticResource NeonPinkBrush}" BorderThickness="1" CornerRadius="4" Padding="8,2" Margin="5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRiskActive}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="🔥 RİSK ALINDI (-5 / +2x)" FontSize="12" FontWeight="Bold" Foreground="{StaticResource NeonPinkBrush}"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Contestant Name Stack with Win Streak Pulsing -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Padding="40,35">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                                <Setter Property="BorderBrush" Value="{StaticResource NeonPinkBrush}"/>
                                <Setter Property="Effect" Value="{StaticResource PinkGlow}"/>
                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform/>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStreakActive}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource NeonOrangeBrush}"/>
                                        <Setter Property="Effect" Value="{StaticResource OrangeGlow}"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard Name="PulseCard">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                     From="1.0" To="1.03" Duration="0:0:0.8"
                                                                     AutoReverse="True" RepeatBehavior="Forever"/>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                     From="1.0" To="1.03" Duration="0:0:0.8"
                                                                     AutoReverse="True" RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="PulseCard"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <!-- Teacher Photo or Initials Avatar -->
                            <Grid Height="120" Width="120" Margin="0,0,0,15" HorizontalAlignment="Center">
                                <!-- Photo Image (Visible if HasPhoto is true) -->
                                <Border CornerRadius="60" BorderThickness="3" BorderBrush="{StaticResource NeonCyanBrush}" ClipToBounds="True" Height="120" Width="120" Effect="{StaticResource CyanGlow}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentTeacher.HasPhoto}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Image Source="{Binding CurrentTeacher.PhotoPath}" Stretch="UniformToFill"/>
                                </Border>
                                
                                <!-- Initials Avatar (Visible if HasPhoto is false) -->
                                <Border CornerRadius="60" BorderThickness="3" BorderBrush="{StaticResource NeonPinkBrush}" Height="120" Width="120" Effect="{StaticResource PinkGlow}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource PinkGradient}"/>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentTeacher.HasPhoto}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding CurrentTeacher.Initials}" Foreground="White" FontSize="44" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                                </Border>
                            </Grid>

                            <TextBlock Text="YARIŞMACI" Foreground="{StaticResource TextMutedBrush}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding CurrentTeacher.Name}" Foreground="White" FontSize="72" FontWeight="Bold" TextAlignment="Center" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Pulse Streak Badge -->
                    <Border Background="#25FF5E00" BorderBrush="{StaticResource NeonOrangeBrush}" BorderThickness="2" CornerRadius="8" Padding="15,8" HorizontalAlignment="Center" Margin="0,15,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Effect" Value="{StaticResource OrangeGlow}"/>
                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform/>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStreakActive}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard Name="PulseBadge">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                     From="1.0" To="1.1" Duration="0:0:0.5"
                                                                     AutoReverse="True" RepeatBehavior="Forever"/>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                     From="1.0" To="1.1" Duration="0:0:0.5"
                                                                     AutoReverse="True" RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="PulseBadge"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🔥 ALEV ALDI! " FontSize="18" FontWeight="Bold" Foreground="{StaticResource NeonOrangeBrush}"/>
                            <TextBlock Text="{Binding CurrentStreak, StringFormat='{}{0} ŞARKI SERİSİ!'}" FontSize="18" FontWeight="Black" Foreground="White"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 10 Seconds Giant Timer -->
                <StackPanel Grid.Row="2" Margin="0,0,0,40">
                    <!-- Simulated Audio Visualizer (Visible during audio play) -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Height="60" Margin="0,0,0,15">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAudioPlaying}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <!-- Bar 1 -->
                        <Rectangle Width="5" Margin="3" Fill="{StaticResource NeonCyanBrush}" RadiusX="2" RadiusY="2" Height="50" RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform>
                                <ScaleTransform ScaleY="1"/>
                            </Rectangle.RenderTransform>
                            <Rectangle.Style>
                                <Style TargetType="Rectangle">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAudioPlaying}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Name="B1">
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.1" To="1.0" Duration="0:0:0.35" AutoReverse="True" RepeatBehavior="Forever"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="B1"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Rectangle.Style>
                        </Rectangle>
                        <!-- Bar 2 -->
                        <Rectangle Width="5" Margin="3" Fill="{StaticResource NeonPinkBrush}" RadiusX="2" RadiusY="2" Height="50" RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform>
                                <ScaleTransform ScaleY="1"/>
                            </Rectangle.RenderTransform>
                            <Rectangle.Style>
                                <Style TargetType="Rectangle">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAudioPlaying}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Name="B2">
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.2" To="0.8" Duration="0:0:0.45" AutoReverse="True" RepeatBehavior="Forever"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="B2"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Rectangle.Style>
                        </Rectangle>
                        <!-- Bar 3 -->
                        <Rectangle Width="5" Margin="3" Fill="{StaticResource NeonYellowBrush}" RadiusX="2" RadiusY="2" Height="50" RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform>
                                <ScaleTransform ScaleY="1"/>
                            </Rectangle.RenderTransform>
                            <Rectangle.Style>
                                <Style TargetType="Rectangle">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAudioPlaying}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Name="B3">
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.15" To="0.9" Duration="0:0:0.25" AutoReverse="True" RepeatBehavior="Forever"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="B3"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Rectangle.Style>
                        </Rectangle>
                        <!-- Bar 4 -->
                        <Rectangle Width="5" Margin="3" Fill="{StaticResource NeonGreenBrush}" RadiusX="2" RadiusY="2" Height="50" RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform>
                                <ScaleTransform ScaleY="1"/>
                            </Rectangle.RenderTransform>
                            <Rectangle.Style>
                                <Style TargetType="Rectangle">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAudioPlaying}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Name="B4">
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.3" To="1.0" Duration="0:0:0.5" AutoReverse="True" RepeatBehavior="Forever"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="B4"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Rectangle.Style>
                        </Rectangle>
                        <!-- Bar 5 -->
                        <Rectangle Width="5" Margin="3" Fill="{StaticResource NeonCyanBrush}" RadiusX="2" RadiusY="2" Height="50" RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform>
                                <ScaleTransform ScaleY="1"/>
                            </Rectangle.RenderTransform>
                            <Rectangle.Style>
                                <Style TargetType="Rectangle">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAudioPlaying}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Name="B5">
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.1" To="0.75" Duration="0:0:0.38" AutoReverse="True" RepeatBehavior="Forever"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="B5"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Rectangle.Style>
                        </Rectangle>
                        <!-- Bar 6 -->
                        <Rectangle Width="5" Margin="3" Fill="{StaticResource NeonPinkBrush}" RadiusX="2" RadiusY="2" Height="50" RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform>
                                <ScaleTransform ScaleY="1"/>
                            </Rectangle.RenderTransform>
                            <Rectangle.Style>
                                <Style TargetType="Rectangle">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAudioPlaying}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Name="B6">
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.25" To="0.95" Duration="0:0:0.42" AutoReverse="True" RepeatBehavior="Forever"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
