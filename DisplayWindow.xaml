            </Grid>

            <!-- STATE: Score (Success Chimes / Confetti) -->
            <Grid Style="{StaticResource ScoreVisibleStyle}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Container: Side-by-side if Last Attempt, else Centered Card -->
                <Grid Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Score Card -->
                    <Border Grid.Column="0" Style="{StaticResource GlassCard}" BorderBrush="{StaticResource NeonGreenBrush}" Effect="{StaticResource GreenGlow}" Width="450" Height="400" Margin="15" Padding="30" VerticalAlignment="Center">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="PERFORMANS TAMAMLANDI" FontSize="14" FontWeight="Bold" Foreground="{StaticResource NeonGreenBrush}" Effect="{StaticResource GreenGlow}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            
                            <TextBlock Text="{Binding CurrentTeacher.Name}" FontSize="36" FontWeight="Bold" Foreground="White" TextAlignment="Center" Margin="0,0,0,20" TextWrapping="Wrap"/>
                            
                            <!-- Total Score -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                                <TextBlock Text="TOPLAM PUAN:" FontSize="18" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding CurrentTeacher.Score}" FontSize="40" FontWeight="Bold" Foreground="{StaticResource NeonYellowBrush}" Effect="{StaticResource CyanGlow}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Grading Status -->
                            <TextBlock Text="{Binding ScoreStatusText}" FontSize="18" FontWeight="Bold" Foreground="White" TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Right: Seyirci Oylaması Panel (Visible ONLY if IsLastAttempt is True) -->
                    <Border Grid.Column="1" Margin="15" Padding="20" Width="420" Height="400" CornerRadius="16" Background="#1C000000" BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="1.5" Effect="{StaticResource CyanGlow}" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLastAttempt}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <!-- Badge -->
                            <Border CornerRadius="6" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource NeonPinkBrush}" BorderThickness="1" HorizontalAlignment="Center" Padding="12,4" Margin="0,0,0,12">
                                <TextBlock Text="SEYİRCİ PERFORMANS OYLAMASI" FontSize="11" FontWeight="Bold" Foreground="{StaticResource NeonPinkBrush}"/>
                            </Border>

                            <!-- Voting Countdown Status -->
                            <TextBlock Text="{Binding VoteStatusText}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource NeonYellowBrush}" Effect="{StaticResource GreenGlow}" TextAlignment="Center" Margin="0,0,0,10"/>

                            <!-- QR Code Image -->
                            <Border BorderThickness="3" BorderBrush="White" CornerRadius="12" Padding="6" Background="White" HorizontalAlignment="Center" Margin="0,0,0,10" Effect="{StaticResource CyanGlow}">
                                <Image Source="{Binding VoteQrCodeUrl}" Width="150" Height="150" Stretch="Uniform"/>
                            </Border>

                            <!-- Direct URL -->
                            <TextBlock Text="veya tarayıcıya yazın: api.eryazilimci.com/vote" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource NeonCyanBrush}" Effect="{StaticResource CyanGlow}" TextAlignment="Center" Margin="0,0,0,12"/>

                            <!-- Stats -->
                            <Grid HorizontalAlignment="Center" Width="300">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="Oy: " FontSize="13" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding VoteCount}" FontSize="15" FontWeight="Bold" Foreground="{StaticResource NeonCyanBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="Ortalama: " FontSize="13" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding VoteAverage, StringFormat={}{0:F1} ★}" FontSize="15" FontWeight="Bold" Foreground="{StaticResource NeonYellowBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Grid.Row="1" Text="{Binding DisplayScoreFooterText}" Foreground="{StaticResource TextMutedBrush}" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            </Grid>

        </Grid>

        <!-- CONFETTI CANVAS OVERLAY -->
        <Canvas x:Name="ConfettiCanvas" IsHitTestVisible="False" Background="Transparent" Panel.ZIndex="999"/>

        <!-- LEADERBOARD OVERLAY -->
        <Grid Background="{StaticResource WindowBgGradient}" Panel.ZIndex="998">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLeaderboardVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            
            <!-- Decorative background glows -->
            <Ellipse Width="300" Height="300" Fill="#0500F2FE" Margin="-150,-150,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Ellipse Width="400" Height="400" Fill="#05FF007F" Margin="0,0,-200,-200" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>

            <Grid Margin="50">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,10,0,30">
                    <TextBlock Text="🏆 LİDERLİK TABLOSU" Style="{StaticResource TitleText}" FontSize="56" HorizontalAlignment="Center" Effect="{StaticResource PinkGlow}"/>
                    <TextBlock Text="En Yüksek Puanlı Yarışmacılar" Style="{StaticResource SubTitleText}" FontSize="22" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Scrollable vertical layout for scoreboard cards -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Style="{StaticResource ModernScrollViewer}">
                    <ItemsControl ItemsSource="{Binding LeaderboardTeachers}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource GlassCard}" Width="550" Height="70" Margin="8" BorderBrush="{StaticResource NeonCyanBrush}" Effect="{StaticResource CyanGlow}">
                                    <Grid Margin="15,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Crown/Star Symbol -->
                                        <TextBlock Grid.Column="0" Text="⭐" FontSize="22" Foreground="{StaticResource NeonYellowBrush}" VerticalAlignment="Center" Margin="5,0,15,0"/>
                                        
                                        <!-- Name -->
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        
                                        <!-- Score Badge -->
                                        <TextBlock Grid.Column="2" Text="{Binding Score, StringFormat='{}{0} Puan'}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource NeonYellowBrush}" Effect="{StaticResource PinkGlow}" VerticalAlignment="Center" Margin="15,0,5,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- WINNER CELEBRATION OVERLAY -->
        <Grid Background="{StaticResource WindowBgGradient}" Panel.ZIndex="997">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsWinnerCelebrationVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <!-- Decorative background glows -->
            <Ellipse Width="500" Height="500" Fill="#15FF007F" HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Trophy Symbol with pulsing animation -->
                <TextBlock Text="🏆" FontSize="110" HorizontalAlignment="Center" Margin="0,0,0,15" Effect="{StaticResource OrangeGlow}">
                    <TextBlock.RenderTransformOrigin>0.5,0.5</TextBlock.RenderTransformOrigin>
                    <TextBlock.RenderTransform>
                        <ScaleTransform/>
                    </TextBlock.RenderTransform>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" From="0.85" To="1.15" Duration="0:0:0.8" AutoReverse="True" RepeatBehavior="Forever"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" From="0.85" To="1.15" Duration="0:0:0.8" AutoReverse="True" RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Text="YARIŞMA ŞAMPİYONU" FontSize="32" FontWeight="Bold" Foreground="{StaticResource NeonYellowBrush}" HorizontalAlignment="Center" Margin="0,0,0,25" Effect="{StaticResource PinkGlow}"/>

                <!-- Winner Photo / Avatar -->
                <Border CornerRadius="100" BorderThickness="5" BorderBrush="{StaticResource NeonYellowBrush}" Width="200" Height="200" HorizontalAlignment="Center" Margin="0,0,0,25" ClipToBounds="True" Effect="{StaticResource OrangeGlow}">
                    <Grid>
                        <!-- Photo Image (Visible if HasPhoto is true) -->
                        <Border CornerRadius="100" ClipToBounds="True">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FinalWinnerTeacher.HasPhoto}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Image Source="{Binding FinalWinnerTeacher.PhotoPath}" Stretch="UniformToFill"/>
                        </Border>
                        
                        <!-- Initials Avatar (Visible if HasPhoto is false) -->
                        <Border CornerRadius="100" Background="{StaticResource PinkGradient}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FinalWinnerTeacher.HasPhoto}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding FinalWinnerTeacher.Initials}" Foreground="White" FontSize="72" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Winner Name and Score -->
                <TextBlock Text="{Binding FinalWinnerTeacher.Name}" FontSize="54" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10" Effect="{StaticResource CyanGlow}"/>
                <TextBlock Text="{Binding FinalWinnerTeacher.Score, StringFormat='{}{0} PUAN'}" FontSize="40" FontWeight="Black" Foreground="{StaticResource NeonGreenBrush}" HorizontalAlignment="Center" Effect="{StaticResource GreenGlow}"/>
            </StackPanel>
        </Grid>


        <!-- Blackout Overlay to cover all contents on demand -->
        <Border x:Name="BlackoutOverlay" Background="Black" Visibility="Collapsed" Panel.ZIndex="999"/>
    </Grid>
</Window>
