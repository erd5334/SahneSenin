                                <Setter Property="Foreground" Value="{StaticResource NeonGreenBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTimerCritical}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource NeonPinkBrush}"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard Name="FlashBarGP">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1.0" To="0.3" Duration="0:0:0.25"
                                                                     AutoReverse="True" RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
