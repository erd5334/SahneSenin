                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1.0" Duration="0:0:0.0"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="B" FontSize="48" FontWeight="Black" Foreground="{StaticResource NeonPinkBrush}" Effect="{StaticResource PinkGlow}" VerticalAlignment="Center" Margin="10,0,20,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding AnswerChoices[1].Text}" FontSize="24" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Option C -->
                    <Border Grid.Row="1" Grid.Column="0" Margin="15" CornerRadius="12" BorderThickness="3">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                                <Setter Property="BorderBrush" Value="#25FFFFFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AnswerChoices[2].IsSelected}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource NeonPinkBrush}"/>
                                        <Setter Property="Effect" Value="{StaticResource PinkGlow}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AnswerChoices[2].IsHidden}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.0" Duration="0:0:0.8"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AnswerChoices[2].IsHidden}" Value="False">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1.0" Duration="0:0:0.0"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="C" FontSize="48" FontWeight="Black" Foreground="{StaticResource NeonPinkBrush}" Effect="{StaticResource PinkGlow}" VerticalAlignment="Center" Margin="10,0,20,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding AnswerChoices[2].Text}" FontSize="24" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Option D -->
                    <Border Grid.Row="1" Grid.Column="1" Margin="15" CornerRadius="12" BorderThickness="3">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                                <Setter Property="BorderBrush" Value="#25FFFFFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AnswerChoices[3].IsSelected}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource NeonPinkBrush}"/>
                                        <Setter Property="Effect" Value="{StaticResource PinkGlow}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AnswerChoices[3].IsHidden}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.0" Duration="0:0:0.8"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AnswerChoices[3].IsHidden}" Value="False">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1.0" Duration="0:0:0.0"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="D" FontSize="48" FontWeight="Black" Foreground="{StaticResource NeonPinkBrush}" Effect="{StaticResource PinkGlow}" VerticalAlignment="Center" Margin="10,0,20,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding AnswerChoices[3].Text}" FontSize="24" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 10 Seconds Giant Timer -->
                <StackPanel Grid.Row="2" Margin="0,0,0,20">
                    <TextBlock Text="{Binding CountdownText}" FontSize="100" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,-15">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource NeonGreenBrush}"/>
                                <Setter Property="Effect" Value="{StaticResource GreenGlow}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTimerCritical}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource NeonPinkBrush}"/>
                                        <Setter Property="Effect" Value="{StaticResource PinkGlow}"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard Name="FlashTextGP">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1.0" To="0.1" Duration="0:0:0.25"
                                                                     AutoReverse="True" RepeatBehavior="Forever"/>
