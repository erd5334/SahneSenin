<Window x:Class="SahneSenin.DisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Sahne Senin - TV Ekranı" Height="600" Width="800"
        Background="{StaticResource WindowBgGradient}"
        WindowStyle="None" WindowState="Normal">

    <Window.Resources>
        <!-- State-based Visibility Styles for TV Screen -->
        <Style x:Key="SetupVisibleStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentState}" Value="Setup">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="SelectionVisibleStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentState}" Value="TeacherSelection">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="GameVisibleStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentState}" Value="Game">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="ScoreVisibleStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentState}" Value="Score">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GuessPhaseVisibleStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentState}" Value="GuessPhase">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Background decorative neon glows -->
        <Ellipse Width="400" Height="400" Fill="#0800F2FE" Margin="-200,-200,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Ellipse Width="500" Height="500" Fill="#08FF007F" Margin="0,0,-250,-250" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>

        <!-- MAIN CONTENT SWITCHER -->
        <Grid Margin="40">
            
            <!-- STATE: Setup -->
            <Grid Style="{StaticResource SetupVisibleStyle}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="SAHNE SENİN" Style="{StaticResource TitleText}" FontSize="72" HorizontalAlignment="Center" Effect="{StaticResource PinkGlow}" Margin="0,0,0,20"/>
                    <TextBlock Text="MÜZİK YARIŞMASINA HOŞ GELDİNİZ" Foreground="{StaticResource NeonCyanBrush}" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" Effect="{StaticResource CyanGlow}" Margin="0,0,0,20"/>
                    <TextBlock Text="Sunucu listeyi yüklediğinde eğlence başlayacak!" Foreground="{StaticResource TextMutedBrush}" FontSize="18" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>

            <!-- STATE: TeacherSelection (Roulette Wheel / Roll list) -->
            <Grid Style="{StaticResource SelectionVisibleStyle}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,20,0,20">
                    <TextBlock Text="SIRADAKİ YARIŞMACI" Style="{StaticResource TitleText}" FontSize="36" HorizontalAlignment="Center" Effect="{StaticResource CyanGlow}"/>
                    <TextBlock Text="Kimin sahnesi olacağını belirleme zamanı!" Style="{StaticResource SubTitleText}" FontSize="18" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Roulette Scroll Container -->
                <Grid Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- The spinning name strip -->
                    <Border Grid.Row="0" x:Name="SpinClipBorder" Width="700" Height="160" ClipToBounds="True"
                            CornerRadius="15" BorderThickness="3" BorderBrush="{StaticResource NeonPinkBrush}"
                            Effect="{StaticResource PinkGlow}" Background="{StaticResource CardBgBrush}">
                        <Grid>
                            <StackPanel x:Name="SpinStackPanel" Orientation="Vertical" VerticalAlignment="Top" HorizontalAlignment="Stretch">
                                <TextBlock Text="ÇARK BEKLENİYOR..." Height="160" FontSize="36" FontWeight="Bold"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           TextAlignment="Center"/>
                            </StackPanel>
                            <!-- Side pointer indicators on top of text -->
                            <Polygon Points="0,0 22,12 0,24" Fill="{StaticResource NeonCyanBrush}"
                                     HorizontalAlignment="Left" VerticalAlignment="Center"
                                     Margin="12,0,0,0" Effect="{StaticResource CyanGlow}"/>
                            <Polygon Points="22,0 0,12 22,24" Fill="{StaticResource NeonCyanBrush}"
                                     HorizontalAlignment="Right" VerticalAlignment="Center"
                                     Margin="0,0,12,0" Effect="{StaticResource CyanGlow}"/>
                        </Grid>
                    </Border>

                    <!-- Winner name shown below the wheel after spin completes -->
                    <Border Grid.Row="1" Margin="0,20,0,0" CornerRadius="12" Padding="30,15"
                            HorizontalAlignment="Center" Background="#20FFFFFF">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSpinCompleted}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="SEÇİLEN YARIŞMACI" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource NeonCyanBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding CurrentTeacher.Name}" FontSize="56" FontWeight="Bold"
                                       Foreground="White" TextAlignment="Center" HorizontalAlignment="Center"
                                       Effect="{StaticResource PinkGlow}"/>
                            <TextBlock Text="Sunucu 'Yarışmayı Başlat' butonuna basana kadar bekleniyor..."
                                       FontSize="14" Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

            </Grid>

            <!-- STATE: Game (Contestant and 10s Countdown) -->
            <Grid Style="{StaticResource GameVisibleStyle}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Contestant Header -->
                <StackPanel Grid.Row="0" Margin="0,20,0,0">
                    <TextBlock Text="SAHNE SENDE!" Style="{StaticResource TitleText}" FontSize="36" Foreground="{StaticResource NeonCyanBrush}" HorizontalAlignment="Center" Effect="{StaticResource CyanGlow}"/>
                    <TextBlock Text="{Binding CurrentAttempt, StringFormat='Hak: {0} / 3'}" Foreground="{StaticResource NeonYellowBrush}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Effect="{StaticResource CyanGlow}" Margin="0,5,0,0"/>
                    <TextBlock Text="Şarkıyı tahmin et ve puanı kap!" Style="{StaticResource SubTitleText}" FontSize="18" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Contestant Name -->
                <Border Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource GlassCard}" BorderBrush="{StaticResource NeonPinkBrush}" Padding="40,35" Effect="{StaticResource PinkGlow}">
                    <StackPanel>
                        <TextBlock Text="YARIŞMACI" Foreground="{StaticResource TextMutedBrush}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding CurrentTeacher.Name}" Foreground="White" FontSize="72" FontWeight="Bold" TextAlignment="Center" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 10 Seconds Giant Timer -->
                <StackPanel Grid.Row="2" Margin="0,0,0,40">
                    <TextBlock Text="{Binding CountdownText}" FontSize="130" FontWeight="Bold" Foreground="{StaticResource NeonPinkBrush}" Effect="{StaticResource PinkGlow}" HorizontalAlignment="Center" Margin="0,0,0,-20"/>
                    <ProgressBar Value="{Binding CountdownProgress}" Maximum="10" Height="25" Width="600" Foreground="{StaticResource NeonPinkBrush}" Background="#25000000" BorderBrush="#35FFFFFF" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- STATE: GuessPhase (Contestant Guessing options) -->
            <Grid Style="{StaticResource GuessPhaseVisibleStyle}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Contestant Header -->
                <StackPanel Grid.Row="0" Margin="0,10,0,10">
                    <TextBlock Text="SAHNE SENDE - TAHMİN ZAMANI!" Style="{StaticResource TitleText}" FontSize="36" Foreground="{StaticResource NeonGreenBrush}" HorizontalAlignment="Center" Effect="{StaticResource GreenGlow}"/>
                    <TextBlock Text="{Binding CurrentAttempt, StringFormat='Hak: {0} / 3'}" Foreground="{StaticResource NeonYellowBrush}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Effect="{StaticResource CyanGlow}" Margin="0,5,0,0"/>
                    <TextBlock Text="Şıklardan doğru olanı söyle veya harfi seç!" Style="{StaticResource SubTitleText}" FontSize="18" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- 4 choices in 2x2 grid -->
                <Grid Grid.Row="1" Margin="20,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Option A -->
                    <Border Grid.Row="0" Grid.Column="0" Margin="15" CornerRadius="12" BorderThickness="3">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                                <Setter Property="BorderBrush" Value="#25FFFFFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AnswerChoices[0].IsSelected}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource NeonPinkBrush}"/>
                                        <Setter Property="Effect" Value="{StaticResource PinkGlow}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="A" FontSize="48" FontWeight="Black" Foreground="{StaticResource NeonPinkBrush}" Effect="{StaticResource PinkGlow}" VerticalAlignment="Center" Margin="10,0,20,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding AnswerChoices[0].Text}" FontSize="24" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Option B -->
                    <Border Grid.Row="0" Grid.Column="1" Margin="15" CornerRadius="12" BorderThickness="3">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                                <Setter Property="BorderBrush" Value="#25FFFFFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AnswerChoices[1].IsSelected}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource NeonPinkBrush}"/>
                                        <Setter Property="Effect" Value="{StaticResource PinkGlow}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="B" FontSize="48" FontWeight="Black" Foreground="{StaticResource NeonPinkBrush}" Effect="{StaticResource PinkGlow}" VerticalAlignment="Center" Margin="10,0,20,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding AnswerChoices[1].Text}" FontSize="24" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Option C -->
                    <Border Grid.Row="1" Grid.Column="0" Margin="15" CornerRadius="12" BorderThickness="3">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                                <Setter Property="BorderBrush" Value="#25FFFFFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AnswerChoices[2].IsSelected}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource NeonPinkBrush}"/>
                                        <Setter Property="Effect" Value="{StaticResource PinkGlow}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="C" FontSize="48" FontWeight="Black" Foreground="{StaticResource NeonPinkBrush}" Effect="{StaticResource PinkGlow}" VerticalAlignment="Center" Margin="10,0,20,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding AnswerChoices[2].Text}" FontSize="24" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Option D -->
                    <Border Grid.Row="1" Grid.Column="1" Margin="15" CornerRadius="12" BorderThickness="3">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                                <Setter Property="BorderBrush" Value="#25FFFFFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AnswerChoices[3].IsSelected}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource NeonPinkBrush}"/>
                                        <Setter Property="Effect" Value="{StaticResource PinkGlow}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="D" FontSize="48" FontWeight="Black" Foreground="{StaticResource NeonPinkBrush}" Effect="{StaticResource PinkGlow}" VerticalAlignment="Center" Margin="10,0,20,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding AnswerChoices[3].Text}" FontSize="24" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 10 Seconds Giant Timer -->
                <StackPanel Grid.Row="2" Margin="0,0,0,20">
                    <TextBlock Text="{Binding CountdownText}" FontSize="100" FontWeight="Bold" Foreground="{StaticResource NeonGreenBrush}" Effect="{StaticResource GreenGlow}" HorizontalAlignment="Center" Margin="0,0,0,-15"/>
                    <ProgressBar Value="{Binding CountdownProgress}" Maximum="10" Height="20" Width="600" Foreground="{StaticResource NeonGreenBrush}" Background="#25000000" BorderBrush="#35FFFFFF" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- STATE: Score (Success Chimes / Confetti) -->
            <Grid Style="{StaticResource ScoreVisibleStyle}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Message Card -->
                <Border Grid.Row="0" Style="{StaticResource GlassCard}" BorderBrush="{StaticResource NeonGreenBrush}" Effect="{StaticResource GreenGlow}" Width="650" Height="300" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="40">
                    <Grid>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding CurrentTeacher.Name}" FontSize="48" FontWeight="Bold" Foreground="White" TextAlignment="Center" Margin="0,0,0,25"/>
                            
                            <!-- Large Status Text -->
                            <TextBlock Text="{Binding ScoreStatusText}" FontSize="36" FontWeight="Bold" Foreground="{StaticResource NeonGreenBrush}" Effect="{StaticResource GreenGlow}" TextAlignment="Center" Margin="0,0,0,25"/>
                            
                            <!-- Updated total score -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="TOPLAM PUAN:" FontSize="20" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding CurrentTeacher.Score}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource NeonYellowBrush}" Effect="{StaticResource CyanGlow}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="1" Text="{Binding DisplayScoreFooterText}" Foreground="{StaticResource TextMutedBrush}" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            </Grid>

        </Grid>

        <!-- CONFETTI CANVAS OVERLAY -->
        <Canvas x:Name="ConfettiCanvas" IsHitTestVisible="False" Background="Transparent"/>
    </Grid>
</Window>
