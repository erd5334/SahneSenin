<Window x:Class="SahneSenin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SahneSenin.ViewModels"
        mc:Ignorable="d"
        Title="Sahne Senin - Sunucu Kontrol Paneli" Height="700" Width="1024"
        Background="{StaticResource WindowBgGradient}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- State-based Visibility Styles -->
        <Style x:Key="SetupVisibleStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentState}" Value="Setup">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SelectionVisibleStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentState}" Value="TeacherSelection">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="GameVisibleStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentState}" Value="Game">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ScoreVisibleStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentState}" Value="Score">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="GuessPhaseVisibleStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentState}" Value="GuessPhase">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Body -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="SAHNE SENİN" Style="{StaticResource TitleText}" FontSize="32" Foreground="{StaticResource NeonCyanBrush}"/>
                <TextBlock Text="Yarışma Yönetim ve Sunucu Paneli" Style="{StaticResource SubTitleText}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Microphone Status Indicator -->
                <Border CornerRadius="8" Padding="12,6" Margin="5" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#1500F2FE"/>
                            <Setter Property="BorderBrush" Value="#4500F2FE"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Effect" Value="{x:Null}"/>
                            <Style.Triggers>
                                <!-- Listening state: glowing green -->
                                <DataTrigger Binding="{Binding SpeechService.IsListening}" Value="True">
                                    <Setter Property="Background" Value="#2000FF87"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource NeonGreenBrush}"/>
                                    <Setter Property="Effect" Value="{StaticResource GreenGlow}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <!-- Tiny glowing dot -->
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource TextMutedBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SpeechService.IsListening}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource NeonGreenBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SpeechService.IsListening}" Value="False">
                                            <Setter Property="Fill" Value="{StaticResource NeonCyanBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding SpeechService.MicStatus}" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Button Content="CSV'den Yükle" Command="{Binding LoadCsvCommand}" Style="{StaticResource NeonCyanButton}" Margin="5" Padding="15,8"/>
                <Button Content="Oyunu Sıfırla" Command="{Binding ResetGameCommand}" Style="{StaticResource NeonButton}" Margin="5" Padding="15,8"/>
            </StackPanel>
        </Grid>

        <!-- Body / Game States Panels -->
        <Grid Grid.Row="1">
            
            <!-- STATE: Setup -->
            <Grid x:Name="SetupPanel" Style="{StaticResource SetupVisibleStyle}">
                <Border Style="{StaticResource GlassCard}" Width="450" Height="250" VerticalAlignment="Center" HorizontalAlignment="Center" BorderBrush="{StaticResource NeonCyanBrush}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Öğretmen Listesi Bulunmadı" FontSize="20" HorizontalAlignment="Center" Foreground="{StaticResource TextWhiteBrush}" Margin="0,0,0,20"/>
                        <TextBlock Text="Lütfen yarışmaya başlamak için sınıf listesini içeren CSV dosyasını yükleyin." TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" Width="350" Margin="0,0,0,20"/>
                        <Button Content="CSV Dosyası Seç" Command="{Binding LoadCsvCommand}" Style="{StaticResource NeonCyanButton}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- STATE: TeacherSelection (Roulette) -->
            <Grid x:Name="SelectionPanel" Style="{StaticResource SelectionVisibleStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/> <!-- Teachers List -->
                    <ColumnDefinition Width="2*"/> <!-- Action Panel -->
                </Grid.ColumnDefinitions>

                <!-- Left: Teachers List -->
                <Border Grid.Column="0" Style="{StaticResource GlassCard}" Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="Öğretmen Listesi ve Skor Durumu" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,15"/>
                        
                        <ListView Grid.Row="1" ItemsSource="{Binding Teachers}" 
                                  Background="Transparent" BorderThickness="0" 
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Margin" Value="0,3"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10">
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#10FFFFFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>
                            
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                        
                                        <!-- Joined artist names joined by comma -->
                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding SelectedArtists}" VerticalAlignment="Center">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#2000F2FE" CornerRadius="4" Padding="6,2" Margin="2">
                                                        <TextBlock Text="{Binding}" FontSize="11" Foreground="{StaticResource NeonCyanBrush}"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Grid.Column="2" Text="{Binding Score, StringFormat='{}{0} Puan'}" FontWeight="Bold" Foreground="{StaticResource NeonYellowBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        
                                        <!-- Played Status Badge -->
                                        <Border Grid.Column="3" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasPlayed}" Value="True">
                                                            <Setter Property="Background" Value="#20FF007F"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding HasPlayed}" Value="False">
                                                            <Setter Property="Background" Value="#2000FF87"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="11" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasPlayed}" Value="True">
                                                                <Setter Property="Text" Value="Oynadı"/>
                                                                <Setter Property="Foreground" Value="{StaticResource NeonPinkBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding HasPlayed}" Value="False">
                                                                <Setter Property="Text" Value="Bekliyor"/>
                                                                <Setter Property="Foreground" Value="{StaticResource NeonGreenBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <!-- Right: Spin & Status -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource GlassCard}" Margin="10,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Yarışma İstatistikleri" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource NeonPinkBrush}" Margin="0,0,0,10"/>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Toplam Öğretmen:" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Teachers.Count}" Foreground="White" FontWeight="Bold"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Sırasını Bekleyen:" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding UnplayedTeachers.Count}" Foreground="{StaticResource NeonGreenBrush}" FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource GlassCard}" Margin="10,10,0,0">
                        <Grid>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Sıradaki Yarışmacıyı Belirle" TextAlignment="Center" FontSize="18" Foreground="{StaticResource TextWhiteBrush}" Margin="0,0,0,25"/>
                                
                                <!-- Button 1: Spin (Visible when IsTeacherSelected is false) -->
                                <Button Content="Rastgele Seç (Çark)" 
                                        Command="{Binding SpinCommand}"
                                        Height="80" Width="220" FontSize="20" FontWeight="Bold"
                                        HorizontalAlignment="Center" Margin="0,0,0,25">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource NeonButton}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTeacherSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Button 2: Start Game (Visible when IsSpinCompleted is true) -->
                                <Button Content="Yarışmayı Başlat" 
                                        Command="{Binding StartGameCommand}"
                                        Height="80" Width="220" FontSize="20" FontWeight="Bold"
                                        HorizontalAlignment="Center" Margin="0,0,0,25">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource NeonGreenButton}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSpinCompleted}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                
                                <TextBlock TextAlignment="Center" FontSize="12" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <!-- Default: spin not started, teacher not selected -->
                                                <DataTrigger Binding="{Binding IsTeacherSelected}" Value="False">
                                                    <Setter Property="Text" Value="Seçilen öğretmen televizyonda çark animasyonu ile yansıyacaktır."/>
                                                </DataTrigger>
                                                <!-- Teacher selected but spin not completed yet (animating) -->
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsTeacherSelected}" Value="True"/>
                                                        <Condition Binding="{Binding IsSpinCompleted}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Text" Value="Çark dönüyor, lütfen animasyonun tamamlanmasını bekleyin..."/>
                                                </MultiDataTrigger>
                                                <!-- Spin completed, ready to start -->
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsTeacherSelected}" Value="True"/>
                                                        <Condition Binding="{Binding IsSpinCompleted}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Text" Value="Öğretmen sahneye çıktığında 'Yarışmayı Başlat' butonuna tıklayın."/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- STATE: Game (Countdown & secret copy) -->
            <Grid x:Name="GamePanel" Style="{StaticResource GameVisibleStyle}">
                <Border Style="{StaticResource GlassCard}" Margin="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Contestant Title -->
                        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <TextBlock Text="{Binding CurrentAttempt, StringFormat='MÜZİK OYNATILIYOR ({0}. HAK)...'}" HorizontalAlignment="Center" FontSize="14" Foreground="{StaticResource NeonPinkBrush}" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding CurrentTeacher.Name}" HorizontalAlignment="Center" FontSize="36" FontWeight="Bold" Foreground="White" Effect="{StaticResource PinkGlow}"/>
                        </StackPanel>

                        <!-- Host Secret Kopya Box -->
                        <Border Grid.Row="1" Background="#1500F2FE" BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="2" CornerRadius="12" Padding="30" Margin="20" Effect="{StaticResource CyanGlow}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="SUNUCU İÇİN DOĞRU CEVAP (KOPYA)" Foreground="{StaticResource NeonCyanBrush}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding SecretSongName}" Foreground="White" FontSize="28" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding CurrentArtist, StringFormat='Tercih Edilen Sanatçı: {0}'}" Foreground="{StaticResource NeonYellowBrush}" FontSize="16" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Playback Status and Grading Overrides -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                             <StackPanel Grid.Column="0" Orientation="Horizontal">
                                 <Button Content="Şarkıyı Yeniden Çal" Command="{Binding ReplayAudioCommand}" Style="{StaticResource NeonCyanButton}" Padding="15,10" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                 <Button Content="Şıklara Geç (10sn)" Command="{Binding GoToGuessPhaseCommand}" Style="{StaticResource NeonButton}" BorderBrush="{StaticResource NeonGreenBrush}" Padding="15,10" VerticalAlignment="Center"/>
                             </StackPanel>

                            <!-- Timer Display -->
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CountdownText, StringFormat='Kalan Süre: {0} Saniye'}" FontSize="18" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <ProgressBar Value="{Binding CountdownProgress}" Maximum="10" Width="300" Height="15" Margin="0,5,0,0" Foreground="{StaticResource NeonPinkBrush}" Background="#20000000" BorderBrush="#35FFFFFF"/>
                            </StackPanel>

                            <!-- Grading Buttons (Host can grade early) -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Content="Bildi (+10)" Command="{Binding GradeCommand}" CommandParameter="Correct" Style="{StaticResource NeonGreenButton}" Padding="15,10" Margin="0,0,10,0"/>
                                <Button Content="Bonus (+15)" Command="{Binding GradeCommand}" CommandParameter="Bonus" Style="{StaticResource NeonButton}" BorderBrush="{StaticResource NeonYellowBrush}" Effect="{StaticResource GreenGlow}" Padding="15,10" Margin="0,0,10,0"/>
                                <Button Content="Bilemedi (0)" Command="{Binding GradeCommand}" CommandParameter="Wrong" Style="{StaticResource NeonButton}" BorderBrush="{StaticResource NeonPinkBrush}" Padding="15,10"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- STATE: GuessPhase (Choice Selection & Timer) -->
            <Grid x:Name="GuessPhasePanel" Style="{StaticResource GuessPhaseVisibleStyle}">
                <Border Style="{StaticResource GlassCard}" Margin="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Contestant Title -->
                        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,15">
                            <TextBlock Text="{Binding CurrentAttempt, StringFormat='TAHMİN SÜRESİ ({0}. HAK)...'}" HorizontalAlignment="Center" FontSize="14" Foreground="{StaticResource NeonGreenBrush}" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding CurrentTeacher.Name}" HorizontalAlignment="Center" FontSize="36" FontWeight="Bold" Foreground="White" Effect="{StaticResource CyanGlow}"/>
                        </StackPanel>

                        <!-- choices list for Host -->
                        <Grid Grid.Row="1" Margin="20,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Button Option A -->
                            <Button Grid.Row="0" Grid.Column="0" Margin="10" Command="{Binding SelectChoiceCommand}" CommandParameter="{Binding AnswerChoices[0]}" Padding="15">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NeonButton}">
                                        <!-- Default border for non-correct/non-selected -->
                                        <Setter Property="BorderBrush" Value="#45FFFFFF"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Effect" Value="{x:Null}"/>
                                        <Style.Triggers>
                                            <!-- Correct choice indicator (Green) -->
                                            <DataTrigger Binding="{Binding AnswerChoices[0].IsCorrect}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource NeonGreenBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource NeonGreenBrush}"/>
                                            </DataTrigger>
                                            <!-- Selected choice indicator (Pink fill) -->
                                            <DataTrigger Binding="{Binding AnswerChoices[0].IsSelected}" Value="True">
                                                <Setter Property="Background" Value="#30FF007F"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource NeonPinkBrush}"/>
                                                <Setter Property="Effect" Value="{StaticResource PinkGlow}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="A" FontSize="20" FontWeight="Bold" Foreground="{StaticResource NeonPinkBrush}" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding AnswerChoices[0].Text}" FontSize="16" FontWeight="SemiBold" TextAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="(DOĞRU)" FontSize="12" Foreground="{StaticResource NeonGreenBrush}" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AnswerChoices[0].IsCorrect}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Button>

                            <!-- Button Option B -->
                            <Button Grid.Row="0" Grid.Column="1" Margin="10" Command="{Binding SelectChoiceCommand}" CommandParameter="{Binding AnswerChoices[1]}" Padding="15">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NeonButton}">
                                        <Setter Property="BorderBrush" Value="#45FFFFFF"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Effect" Value="{x:Null}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AnswerChoices[1].IsCorrect}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource NeonGreenBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource NeonGreenBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AnswerChoices[1].IsSelected}" Value="True">
                                                <Setter Property="Background" Value="#30FF007F"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource NeonPinkBrush}"/>
                                                <Setter Property="Effect" Value="{StaticResource PinkGlow}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="B" FontSize="20" FontWeight="Bold" Foreground="{StaticResource NeonPinkBrush}" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding AnswerChoices[1].Text}" FontSize="16" FontWeight="SemiBold" TextAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="(DOĞRU)" FontSize="12" Foreground="{StaticResource NeonGreenBrush}" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AnswerChoices[1].IsCorrect}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Button>

                            <!-- Button Option C -->
                            <Button Grid.Row="1" Grid.Column="0" Margin="10" Command="{Binding SelectChoiceCommand}" CommandParameter="{Binding AnswerChoices[2]}" Padding="15">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NeonButton}">
                                        <Setter Property="BorderBrush" Value="#45FFFFFF"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Effect" Value="{x:Null}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AnswerChoices[2].IsCorrect}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource NeonGreenBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource NeonGreenBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AnswerChoices[2].IsSelected}" Value="True">
                                                <Setter Property="Background" Value="#30FF007F"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource NeonPinkBrush}"/>
                                                <Setter Property="Effect" Value="{StaticResource PinkGlow}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="C" FontSize="20" FontWeight="Bold" Foreground="{StaticResource NeonPinkBrush}" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding AnswerChoices[2].Text}" FontSize="16" FontWeight="SemiBold" TextAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="(DOĞRU)" FontSize="12" Foreground="{StaticResource NeonGreenBrush}" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AnswerChoices[2].IsCorrect}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Button>

                            <!-- Button Option D -->
                            <Button Grid.Row="1" Grid.Column="1" Margin="10" Command="{Binding SelectChoiceCommand}" CommandParameter="{Binding AnswerChoices[3]}" Padding="15">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NeonButton}">
                                        <Setter Property="BorderBrush" Value="#45FFFFFF"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Effect" Value="{x:Null}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AnswerChoices[3].IsCorrect}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource NeonGreenBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource NeonGreenBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AnswerChoices[3].IsSelected}" Value="True">
                                                <Setter Property="Background" Value="#30FF007F"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource NeonPinkBrush}"/>
                                                <Setter Property="Effect" Value="{StaticResource PinkGlow}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="D" FontSize="20" FontWeight="Bold" Foreground="{StaticResource NeonPinkBrush}" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding AnswerChoices[3].Text}" FontSize="16" FontWeight="SemiBold" TextAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="(DOĞRU)" FontSize="12" Foreground="{StaticResource NeonGreenBrush}" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AnswerChoices[3].IsCorrect}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Button>
                        </Grid>

                        <!-- Bottom Controls -->
                        <Grid Grid.Row="2" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Confirm Button -->
                            <Button Grid.Column="0" Content="Cevabı Onayla" Command="{Binding ConfirmAnswerCommand}" Style="{StaticResource NeonGreenButton}" Width="160" Height="45" VerticalAlignment="Center"/>

                            <!-- Timer Display -->
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CountdownText, StringFormat='Kalan Tahmin Süresi: {0} Saniye'}" FontSize="16" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <ProgressBar Value="{Binding CountdownProgress}" Maximum="10" Width="250" Height="12" Margin="0,5,0,0" Foreground="{StaticResource NeonGreenBrush}" Background="#20000000" BorderBrush="#35FFFFFF"/>
                            </StackPanel>

                            <!-- Manual Override Buttons -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Doğru (+10)" Command="{Binding GradeCommand}" CommandParameter="Correct" Style="{StaticResource NeonGreenButton}" Padding="15,10" Margin="0,0,10,0"/>
                                <Button Content="Bilemedi (0)" Command="{Binding GradeCommand}" CommandParameter="Wrong" Style="{StaticResource NeonButton}" BorderBrush="{StaticResource NeonPinkBrush}" Padding="15,10"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- STATE: Score -->
            <Grid x:Name="ScorePanel" Style="{StaticResource ScoreVisibleStyle}">
                <Border Style="{StaticResource GlassCard}" Width="600" Height="450" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="PUANLAMA EKRANI" HorizontalAlignment="Center" FontSize="16" Foreground="{StaticResource NeonYellowBrush}" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding CurrentTeacher.Name}" HorizontalAlignment="Center" FontSize="36" FontWeight="Bold" Foreground="White" Effect="{StaticResource CyanGlow}"/>
                        </StackPanel>

                        <!-- Answer Details & Selected Grade -->
                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <Border CornerRadius="8" Background="#10FFFFFF" Padding="15" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="Şarkı:" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" FontSize="12" Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding SecretSongName}" Foreground="White" FontSize="20" FontWeight="SemiBold" TextAlignment="Center" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="{Binding ScoreStatusText}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource NeonGreenBrush}" HorizontalAlignment="Center" TextAlignment="Center"/>
                            
                            <!-- If they came from countdown finished, grading buttons are active here -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                                <Button Content="Bildi (+10)" Command="{Binding GradeCommand}" CommandParameter="Correct" Style="{StaticResource NeonGreenButton}" Width="110" Height="45" Margin="0,0,15,0"/>
                                <Button Content="Bonus (+15)" Command="{Binding GradeCommand}" CommandParameter="Bonus" Style="{StaticResource NeonButton}" BorderBrush="{StaticResource NeonYellowBrush}" Width="110" Height="45" Margin="0,0,15,0"/>
                                <Button Content="Bilemedi (0)" Command="{Binding GradeCommand}" CommandParameter="Wrong" Style="{StaticResource NeonButton}" BorderBrush="{StaticResource NeonPinkBrush}" Width="110" Height="45"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Next Attempt Button -->
                        <Button Grid.Row="2" Content="{Binding NextAttemptButtonText}"
                                Command="{Binding NextAttemptCommand}" 
                                Height="50" FontSize="16" FontWeight="Bold" Margin="0,20,0,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NeonGreenButton}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsNotLastAttempt}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Back to List button -->
                        <Button Grid.Row="2" Content="Listeye Dön (Sonraki Yarışmacı)" 
                                Command="{Binding BackToSelectionCommand}" 
                                Height="50" FontSize="16" FontWeight="Bold" Margin="0,20,0,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NeonCyanButton}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLastAttempt}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
            
        </Grid>

        <!-- Footer -->
        <StatusBar Grid.Row="2" Background="Transparent" BorderBrush="#15FFFFFF" BorderThickness="0,1,0,0" Padding="5,10,5,0">
            <StatusBarItem>
                <TextBlock Text="Sahne Senin © 2026 - Perşembe Eğlencesi Müzik Yarışması" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding CurrentState, StringFormat='Durum: {0}'}" Foreground="{StaticResource NeonCyanBrush}" FontSize="11" FontWeight="Bold"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
