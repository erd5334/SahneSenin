<Window x:Class="SahneSenin.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Puanlama Ayarları" Height="650" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        BorderBrush="{StaticResource NeonCyanBrush}"
        BorderThickness="2"
        Foreground="White">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="PUANLAMA AYARLARI" Style="{StaticResource TitleText}" FontSize="24" HorizontalAlignment="Center" Effect="{StaticResource CyanGlow}"/>
            <TextBlock Text="Yarışma modlarının puan ve ceza değerlerini özelleştirin." Style="{StaticResource SubTitleText}" FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Scrollable settings panel -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15" Focusable="False">
            <StackPanel Margin="0,0,10,0">
                <!-- Group 1: Normal Mod -->
                <Border Style="{StaticResource GlassCard}" BorderBrush="{StaticResource NeonCyanBrush}" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Normal Mod (Kendi Sanatçıları)" FontSize="14" FontWeight="Bold" Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Doğru Tahmin Puanı:" VerticalAlignment="Center" Foreground="White"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtNormalCorrect" Width="70" Height="25" HorizontalAlignment="Right" VerticalAlignment="Center" TextAlignment="Center" Background="#110C24" Foreground="White" BorderBrush="#5500F2FE" BorderThickness="1.5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Harika Performans (Bonus):" VerticalAlignment="Center" Foreground="White"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtNormalBonus" Width="70" Height="25" HorizontalAlignment="Right" VerticalAlignment="Center" TextAlignment="Center" Background="#110C24" Foreground="White" BorderBrush="#5500F2FE" BorderThickness="1.5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Yanlış Tahmin Cezası:" VerticalAlignment="Center" Foreground="White"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtNormalWrong" Width="70" Height="25" HorizontalAlignment="Right" VerticalAlignment="Center" TextAlignment="Center" Background="#110C24" Foreground="White" BorderBrush="#5500F2FE" BorderThickness="1.5"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Group 2: Tüm Sanatçı Havuzu -->
                <Border Style="{StaticResource GlassCard}" BorderBrush="{StaticResource NeonYellowBrush}" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Tüm Sanatçı Havuzu Modu" FontSize="14" FontWeight="Bold" Foreground="{StaticResource NeonYellowBrush}" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Doğru Tahmin Puanı:" VerticalAlignment="Center" Foreground="White"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtPoolCorrect" Width="70" Height="25" HorizontalAlignment="Right" VerticalAlignment="Center" TextAlignment="Center" Background="#110C24" Foreground="White" BorderBrush="#55FFE600" BorderThickness="1.5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Harika Performans (Bonus):" VerticalAlignment="Center" Foreground="White"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtPoolBonus" Width="70" Height="25" HorizontalAlignment="Right" VerticalAlignment="Center" TextAlignment="Center" Background="#110C24" Foreground="White" BorderBrush="#55FFE600" BorderThickness="1.5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Yanlış Tahmin Cezası:" VerticalAlignment="Center" Foreground="White"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtPoolWrong" Width="70" Height="25" HorizontalAlignment="Right" VerticalAlignment="Center" TextAlignment="Center" Background="#110C24" Foreground="White" BorderBrush="#55FFE600" BorderThickness="1.5"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Group 3: Ekstra Sanatçı -->
                <Border Style="{StaticResource GlassCard}" BorderBrush="{StaticResource NeonPinkBrush}" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Ekstra Sanatçı Seçimi" FontSize="14" FontWeight="Bold" Foreground="{StaticResource NeonPinkBrush}" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Doğru Tahmin Puanı:" VerticalAlignment="Center" Foreground="White"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtExtraCorrect" Width="70" Height="25" HorizontalAlignment="Right" VerticalAlignment="Center" TextAlignment="Center" Background="#110C24" Foreground="White" BorderBrush="#55FF007F" BorderThickness="1.5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Harika Performans (Bonus):" VerticalAlignment="Center" Foreground="White"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtExtraBonus" Width="70" Height="25" HorizontalAlignment="Right" VerticalAlignment="Center" TextAlignment="Center" Background="#110C24" Foreground="White" BorderBrush="#55FF007F" BorderThickness="1.5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Yanlış Tahmin Cezası:" VerticalAlignment="Center" Foreground="White"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtExtraWrong" Width="70" Height="25" HorizontalAlignment="Right" VerticalAlignment="Center" TextAlignment="Center" Background="#110C24" Foreground="White" BorderBrush="#55FF007F" BorderThickness="1.5"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Group 4: Risk Al -->
                <Border Style="{StaticResource GlassCard}" BorderBrush="{StaticResource NeonOrangeBrush}" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Risk Al (Çifte Şans) Ayarları" FontSize="14" FontWeight="Bold" Foreground="{StaticResource NeonOrangeBrush}" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Doğru Tahmin Çarpanı (Kat):" VerticalAlignment="Center" Foreground="White"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtRiskMultiplier" Width="70" Height="25" HorizontalAlignment="Right" VerticalAlignment="Center" TextAlignment="Center" Background="#110C24" Foreground="White" BorderBrush="#55FF5E00" BorderThickness="1.5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Bilememe Cezası:" VerticalAlignment="Center" Foreground="White"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtRiskWrong" Width="70" Height="25" HorizontalAlignment="Right" VerticalAlignment="Center" TextAlignment="Center" Background="#110C24" Foreground="White" BorderBrush="#55FF5E00" BorderThickness="1.5"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Vazgeç" Click="CancelButton_Click" Style="{StaticResource NeonButton}" Width="100" Margin="0,0,10,0" BorderBrush="{StaticResource TextMutedBrush}"/>
            <Button Content="Kaydet" Click="SaveButton_Click" Style="{StaticResource NeonCyanButton}" Width="120"/>
        </StackPanel>
    </Grid>
</Window>
